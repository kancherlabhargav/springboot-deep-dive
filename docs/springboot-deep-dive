&nbsp;&nbsp;<span class="k">private int</span> expiryMinutes;<br>
&nbsp;&nbsp;<span class="c">// getters/setters or use @Value + @ConfigurationPropertiesScan with records</span><br>
}<br><br>
<span class="c">// Inject and use:</span><br>
<span class="k">public class</span> <span class="t">JwtService</span> {<br>
&nbsp;&nbsp;<span class="k">private final</span> <span class="t">JwtProperties</span> jwtProps;<span class="c"> // injected</span><br>
&nbsp;&nbsp;<span class="k">public</span> <span class="t">String</span> <span class="m">generateToken</span>(<span class="t">String</span> sub) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="k">return</span> Jwts.<span class="m">builder</span>()<br>
