&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;.<span class="m">signWith</span>(jwtProps.<span class="m">getSecret</span>())<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;.<span class="m">compact</span>();<br>
