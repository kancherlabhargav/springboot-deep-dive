&nbsp;&nbsp;&nbsp;&nbsp;cacheRepo.<span class="m">loadProducts</span>();<br>
&nbsp;&nbsp;}<br><br>
&nbsp;&nbsp;<span class="a">@PreDestroy</span>   <span class="c">// runs before bean is destroyed (app shutdown)</span><br>
&nbsp;&nbsp;<span class="k">public void</span> <span class="m">flushCache</span>() {<br>
&nbsp;&nbsp;&nbsp;&nbsp;cacheRepo.<span class="m">flush</span>();<br>
&nbsp;&nbsp;}<br>
}
