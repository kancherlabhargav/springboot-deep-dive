    <a class="sidebar-link" href="#validation">Validation</a>

    <div class="sidebar-section">Data Layer</div>
    <a class="sidebar-link" href="#jpa">JPA & Hibernate</a>
    <a class="sidebar-link" href="#transactions">Transactions</a>

    <div class="sidebar-section">Config & Profiles</div>
    <a class="sidebar-link" href="#config">Configuration</a>
    <a class="sidebar-link" href="#profiles">Profiles</a>

    <div class="sidebar-section">Security & More</div>
    <a class="sidebar-link" href="#security">Spring Security</a>
